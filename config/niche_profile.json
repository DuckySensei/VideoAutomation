{
  "niche_name": "Reddit Drama Stories",
  "target_audience": "People who watch dramatic story breakdowns, relationship conflict, and social dilemma takes.",
  "platform_primary": "youtube_shorts",
  "content_templates": [
    {
      "id": "hook_3tips_cta",
      "name": "Hook + What Happened + Stakes + CTA",
      "duration_seconds_target": 35,
      "structure": [
        "Hook (high tension opening line)",
        "What happened (concise context)",
        "Why this is messy (conflict and stakes)",
        "Viewer verdict prompt",
        "CTA (ask if they want Part 2)"
      ]
    },
    {
      "id": "myth_vs_fact",
      "name": "OP vs Comment Section",
      "duration_seconds_target": 30,
      "structure": [
        "OP claim in one line",
        "Counterpoint in one line",
        "Who looks wrong and why",
        "One cautionary takeaway",
        "CTA for verdict"
      ]
    },
    {
      "id": "top3_in_30s",
      "name": "Parted Story in 30s",
      "duration_seconds_target": 30,
      "structure": [
        "Set up the conflict",
        "Escalation beat",
        "Twist or reveal",
        "Current outcome",
        "CTA for next part"
      ]
    }
  ],
  "constraints": {
    "max_title_chars": 70,
    "max_description_chars": 2200,
    "must_be_transformative": true,
    "copyright_policy": "Only creator-owned, commercially licensed, or clearly permitted CC assets."
  }
}
